local function makeDraggable(obj)
    local dragging, dragStart, startPos
    obj.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = obj.Position
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - dragStart
            obj.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
    UserInputService.InputEnded:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then dragging = false end end)
end
makeDraggable(MainFrame)
makeDraggable(ToggleMainBtn)
local enabled = false
local originalDistances = {}
local function applyToPrompt(prompt, addedValue)
    if not prompt:IsA("ProximityPrompt") then return end
    if not originalDistances[prompt] then originalDistances[prompt] = prompt.MaxActivationDistance end
    prompt.MaxActivationDistance = originalDistances[prompt] + addedValue
end
local function restorePrompt(prompt)
    if not prompt:IsA("ProximityPrompt") then return end
    if originalDistances[prompt] then
        prompt.MaxActivationDistance = originalDistances[prompt]
        originalDistances[prompt] = nil
    end
end
local function toggle(state)
    enabled = state
    if enabled then
        local addedValue = tonumber(TextBox.Text) or 0
        ToggleBtn.Text = "Enabled"
        ToggleBtn.BackgroundColor3 = Color3.fromRGB(50, 160, 50)
        for _, d in ipairs(Workspace:GetDescendants()) do applyToPrompt(d, addedValue) end
    else
        ToggleBtn.Text = "Disabled"
        ToggleBtn.BackgroundColor3 = Color3.fromRGB(180, 50, 50)
        for p, d in pairs(originalDistances) do if p and p.Parent then p.MaxActivationDistance = d end end
        table.clear(originalDistances)
    end
end
ToggleBtn.MouseButton1Click:Connect(function() toggle(not enabled) end)
Workspace.DescendantAdded:Connect(function(d) if enabled then applyToPrompt(d, tonumber(TextBox.Text) or 0) end end)
